// VisionCut AI — Prisma schema
// All vectors are stored as pgvector columns via Unsupported() because Prisma
// does not yet have first-class pgvector support.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector, pgcrypto]
}

enum Plan {
  free
  pro
}

enum ProjectStatus {
  uploading
  analyzing
  building
  rendering
  done
  failed
}

enum ClipType {
  reference
  user
  music
  sfx
  voiceover
}

enum FeedbackRating {
  up
  down
}

enum AnalyticsEventType {
  project_created
  project_analyzed
  timeline_built
  render_started
  render_done
  render_failed
  feedback_given
  style_saved
  style_applied
}

// ============== USERS ==============

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  plan          Plan     @default(free)
  credits       Int      @default(2)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects      Project[]
  styles        Style[]
  feedback      Feedback[]
  preferences   UserPreference?
  analytics     AnalyticsEvent[]

  @@index([email])
}

// ============== PROJECTS ==============

model Project {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @db.Uuid
  name          String
  description   String?
  status        ProjectStatus @default(uploading)
  referenceUrl  String?
  blueprint     Json?
  timeline      Json?
  qualityScore  Float?
  errorMessage  String?
  progress      Int           @default(0)
  currentStep   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clips         Clip[]
  segments      TimelineSegment[]
  feedback      Feedback[]
  analytics     AnalyticsEvent[]

  @@index([userId])
  @@index([status])
  @@index([userId, createdAt])
}

// ============== CLIPS ==============

model Clip {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @db.Uuid
  name        String
  url         String
  type        ClipType @default(user)
  durationSec Float?
  sizeBytes   BigInt?
  mimeType    String?

  // Visual analysis results
  sceneType   String?
  motionLevel Float?
  cameraMove  String?
  quality     Float?
  lighting    String?
  objects     Json?
  faces       Int?
  metadata    Json?

  // 512-dim FAISS embedding for similarity search
  embedding   Unsupported("vector(512)")?

  // 256-dim style vector (only set for reference clips)
  styleVector Unsupported("vector(256)")?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, type])
}

// ============== TIMELINE SEGMENTS ==============

model TimelineSegment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String   @db.Uuid
  position      Int
  startTime     Float
  endTime       Float
  clipId        String?  @db.Uuid
  transition    String?
  transitionDur Float    @default(0.3)
  confidence    Float
  matchReason   Json?
  alternatives  Json?
  renderPath    String?

  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, position])
}

// ============== STYLES (Module 17) ==============

model Style {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @db.Uuid
  name            String
  description     String?
  contentType     String?
  pace            String?
  transitions     Json?
  audioComponents Json?
  blueprintTemplate Json?
  styleVector     Unsupported("vector(256)")?
  isPublic        Boolean  @default(false)
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contentType])
}

// ============== FEEDBACK (Module 18) ==============

model Feedback {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @db.Uuid
  projectId   String         @db.Uuid
  segmentId   String?        @db.Uuid
  clipId      String?        @db.Uuid
  rating      FeedbackRating
  comment     String?
  createdAt   DateTime       @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([userId, createdAt])
}

// ============== USER PREFERENCES (Module 18) ==============

model UserPreference {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @unique @db.Uuid
  preferredTransitions Json?
  preferredPace        String?
  preferredContentTypes Json?
  featureWeights       Json?
  totalFeedback        Int      @default(0)
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============== ANALYTICS (Module 19) ==============

model AnalyticsEvent {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String             @db.Uuid
  projectId   String?            @db.Uuid
  eventType   AnalyticsEventType
  payload     Json?
  createdAt   DateTime           @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}
