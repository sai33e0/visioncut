# ============================================
# VisionCut AI — Environment Configuration
# ============================================
# Copy this file to `.env` and fill in real values.
# All values below are local-development defaults; override per environment.

# ---------- Core ----------
NODE_ENV=development
APP_NAME=VisionCut AI
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ---------- Database (Supabase / PostgreSQL) ----------
# For pure local dev you can use a postgres container; see docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# ---------- Redis (job queue + cache) ----------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------- Cloudflare R2 (object storage) ----------
# Falls back to local filesystem (./storage) when R2 keys are missing.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=visioncut-media
R2_PUBLIC_URL=http://localhost:3001/media

# ---------- AI Providers ----------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- JWT / Auth ----------
JWT_SECRET=replace-with-32-char-random-string
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace-with-different-random-string
REFRESH_TOKEN_EXPIRES_IN=30d

# ---------- Worker Service URLs ----------
REFERENCE_ANALYZER_URL=http://localhost:8001
CLIP_ANALYZER_URL=http://localhost:8002
TIMELINE_BUILDER_URL=http://localhost:8003
RENDERER_URL=http://localhost:8004
STYLE_ENGINE_URL=http://localhost:8005
FEEDBACK_ENGINE_URL=http://localhost:8006

# ---------- WebSocket ----------
WS_PORT=3002
WS_CORS_ORIGIN=http://localhost:3000

# ---------- Render / FFmpeg ----------
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
RENDER_USE_GPU=false
RENDER_PRESET=veryfast
RENDER_CRF=23

# ---------- Observability ----------
SENTRY_DSN=
LOG_LEVEL=info

# ---------- Rate Limits ----------
RATE_LIMIT_SHORT=5
RATE_LIMIT_MEDIUM=100
RATE_LIMIT_LONG=500

# ---------- File Upload Limits (bytes) ----------
MAX_REFERENCE_VIDEO=524288000
MAX_CLIP=209715200
MAX_MUSIC=52428800
MAX_SFX=10485760
MAX_VOICEOVER=52428800

# ---------- Plans ----------
FREE_PLAN_PROJECTS_PER_MONTH=2
PRO_PLAN_PROJECTS_PER_MONTH=-1
FREE_PLAN_CREDITS=2
